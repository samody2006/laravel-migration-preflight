{
  "name": "samody/laravel-migration-preflight",
  "description": "Pre-migration validation tool for Laravel migrations",
  "type": "library",
  "license": "MIT",

  "keywords": [
    "laravel",
    "migrations",
    "preflight",
    "tool",
    "database"
  ],

  "homepage": "https://github.com/samody/laravel-migration-preflight",

  "support": {
    "issues": "https://github.com/samody/laravel-migration-preflight/issues",
    "source": "https://github.com/samody/laravel-migration-preflight"
  },

  "authors": [
    {
      "name": "Samson Radje",
      "email": "samody2006@gmail.com",
      "role": "Maintainer"
    }
  ],

  "require": {
    "php": ">=8.1"
  },

  "require-dev": {
    "orchestra/testbench": "^8.0",
    "phpunit/phpunit": "^10.0"
  },

  "autoload": {
    "psr-4": {
      "MigrationPreflight\\": "src/"
    }
  },

  "autoload-dev": {
    "psr-4": {
      "MigrationPreflight\\Tests\\": "tests/"
    }
  },

  "extra": {
    "laravel": {
      "providers": [
        "MigrationPreflight\\MigrationPreflightServiceProvider"
      ]
    }
  },

  "minimum-stability": "stable",
  "prefer-stable": true
}