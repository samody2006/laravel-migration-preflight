{
  "name": "samody/laravel-migration-preflight",
  "description": "Pre-migration validation tool for Laravel migrations",
  "type": "library",
  "license": "MIT",
    "keywords": [
        "table",
        "migrations",
        "preflight",
	"tool",
        "laravel"
    ],
    "authors": [
        {
            "name": "Samson Radje",
            "email": "samody2006@gmail.com",
            "role": "Developer"
        }
    ],
  "require": {
    "php": ">=8.1",
    "illuminate/support": "^10.0|^11.0"
  },
  "autoload": {
    "psr-4": {
      "MigrationPreflight\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "MigrationPreflight\\MigrationPreflightServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}